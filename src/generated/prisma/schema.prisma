generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserProfile {
  userId     Int      @id
  profilePic String?
  tags       String[]
  user       User     @relation(fields: [userId], references: [id])
}

model User {
  id           Int          @id @default(autoincrement())
  userName     String       @unique
  userEmail    String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  isAdmin      Boolean      @default(false)
  discussions  Discussion[]
  replies      Reply[]
  essays       Essay[]
  profile      UserProfile?
}

model Reply {
  id           Int        @id @default(autoincrement())
  text         String
  title        String
  authorId     Int
  discussionId Int
  createdAt    DateTime   @default(now())
  parentId     Int?
  author       User       @relation(fields: [authorId], references: [id])
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parent       Reply?     @relation("ReplyToReply", fields: [parentId], references: [id])
  children     Reply[]    @relation("ReplyToReply")
}

model Discussion {
  id        Int      @id @default(autoincrement())
  text      String
  authorId  Int
  title     String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  replies   Reply[]
}

model Weekly {
  id                       Int                 @id @default(1)
  saintName                String              @default("")
  saintDescription         String              @default("")
  saintFeastDay            String              @default("")
  featuredScriptureRef     String              @default("")
  featuredScriptureSummary String              @default("")
  discussionTitle          String              @default("")
  discussionDescription    String              @default("")
  discussionImage          String              @default("")
  discussionCloses         String              @default("")
  citations                ScriptureCitation[]
  featuredEssays           Essay[]
}

model Essay {
  id        Int      @id @default(autoincrement())
  title     String
  category  String
  text      String
  createdAt DateTime @default(now())

  authorId Int
  author   User @relation(fields: [authorId], references: [id])

  // Many-to-Many: Connects back to the Weekly models that feature it
  featuredIn Weekly[]
}

model ScriptureCitation {
  id        Int    @id @default(autoincrement())
  reference String
  summary   String
  weeklyId  Int
  weekly    Weekly @relation(fields: [weeklyId], references: [id], onDelete: Cascade)
}
