generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model UserProfile {
  userId     Int      @id
  profilePic String?
  tags       String[]
  user       User     @relation(fields: [userId], references: [id])
}

model User {
  id           Int          @id @default(autoincrement())
  userName     String       @unique
  userEmail    String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  isAdmin      Boolean      @default(false)
  discussions  Discussion[]
  replies      Reply[]
  essays       Essay[]
  profile      UserProfile?
}

model Reply {
  id           Int        @id @default(autoincrement())
  text         String
  title        String
  authorId     Int
  discussionId Int
  createdAt    DateTime   @default(now())
  parentId     Int?
  author       User       @relation(fields: [authorId], references: [id])
  discussion   Discussion @relation(fields: [discussionId], references: [id])
  parent       Reply?     @relation("ReplyToReply", fields: [parentId], references: [id])
  children     Reply[]    @relation("ReplyToReply")
}

model Discussion {
  id        Int      @id @default(autoincrement())
  text      String
  authorId  Int
  title     String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  replys    Reply[]
}

model Weekly {
  id               Int                 @id @default(autoincrement())
  saintName        String
  saintDescription String
  saintFeastDay    String
  // 1-to-Many: A week can have multiple scripture citations
  citation         ScriptureCitation[]
  // Many-to-Many: Implicit relation link to featured essays
  featuredEssays   Essay[]             
}

model Essay {
  id         Int      @id @default(autoincrement())
  title      String
  category   String
  text       String
  createdAt  DateTime @default(now())
  
  authorId   Int
  author     User     @relation(fields: [authorId], references: [id])

  // Many-to-Many: Connects back to the Weekly models that feature it
  featuredIn Weekly[] 
}

model ScriptureCitation {
  id               Int      @id @default(autoincrement())
  scriptureBook    String
  scriptureChapter String
  scriptureVerse   String
  featuredInWeeks  Weekly[] 
}
